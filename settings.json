{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run fix:prettier 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read(/.env.local.example)",
      "Bash(npm run *)",
      "Bash(* --version)",
      "Bash(* --help *)"
    ],
    "deny": [
      "Read(*.env*)",
      "Edit(*.env*)",
      "Bash(cat *.env*)",
      "Bash(head *.env*)",
      "Bash(vim *.env*)",
      "Bash(vi *.env*)",
      "Bash(nano *.env*)",
      "Bash(code *.env*)",
      "Bash(open *.env*)",
      "Bash(source *.env*)",
      "Bash(. *.env*)",
      "Read(~/.ssh/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git * main)"
    ]
  }
}
